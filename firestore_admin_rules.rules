rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // ADMINS COLLECTION (Web Admin only)
    // ========================================
    match /admins/{adminId} {
      // Allow authenticated users to create admin profile during registration
      allow create: if request.auth != null && 
                      request.resource.data.role == 'admin' &&
                      request.resource.data.email == request.auth.token.email;
      
      // Allow admins to read all admin profiles
      allow read: if request.auth != null && 
                     (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Allow admin to update their own profile
      allow update: if request.auth != null && request.auth.uid == adminId;
      
      // Only super admin can delete
      allow delete: if request.auth != null && 
                       get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isSuperAdmin == true;
    }
    
    // ========================================
    // USERS COLLECTION (Mobile App + Admin)
    // ========================================
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || 
                      get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Users can create their own profile during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Users can update their own data, admins can update any
      allow update: if request.auth != null && 
                       (request.auth.uid == userId || 
                        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Only admins can delete users
      allow delete: if request.auth != null && 
                       (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // PRACTICE SESSIONS COLLECTION
    // ========================================
    match /practice_sessions/{sessionId} {
      // Users can read their own sessions, admins can read all
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid ||
                      get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Users can create their own sessions
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own sessions, admins can update any
      allow update: if request.auth != null && 
                       (resource.data.userId == request.auth.uid ||
                        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Users can delete their own sessions, admins can delete any
      allow delete: if request.auth != null && 
                       (resource.data.userId == request.auth.uid ||
                        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // QUESTIONS COLLECTION (Admin managed)
    // ========================================
    match /questions/{questionId} {
      // Anyone authenticated can read questions
      allow read: if request.auth != null;
      
      // Only admins can create, update, delete questions
      allow create, update, delete: if request.auth != null && 
                                       (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // STATISTICS COLLECTION (Read-only for users)
    // ========================================
    match /statistics/{statId} {
      // Authenticated users can read stats
      allow read: if request.auth != null;
      
      // Only admins can write stats
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // LEADERBOARD COLLECTION
    // ========================================
    match /leaderboard/{userId} {
      // Anyone authenticated can read leaderboard
      allow read: if request.auth != null;
      
      // System/Admin only can write
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // FEEDBACK COLLECTION
    // ========================================
    match /feedback/{feedbackId} {
      // Users can read their own feedback, admins can read all
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid ||
                      get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Anyone can create feedback
      allow create: if request.auth != null;
      
      // Admins can update/delete feedback
      allow update, delete: if request.auth != null && 
                               (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // ========================================
    // SETTINGS COLLECTION (Admin only)
    // ========================================
    match /settings/{settingId} {
      // Admins can read settings
      allow read: if request.auth != null && 
                     (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      // Only admins can write settings
      allow write: if request.auth != null && 
                      (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
