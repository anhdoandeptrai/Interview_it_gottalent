rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ========================================
    // HELPER FUNCTIONS
    // ========================================
    
    // Check if user is admin
    function isAdmin() {
      return request.auth != null && 
             (firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role == 'admin' ||
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Check if user owns the file
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // ========================================
    // PDF FILES (User uploads - CV, Presentations)
    // ========================================
    match /pdfs/{userId}/{fileName} {
      // Users can read their own PDFs, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can upload their own PDFs
      allow create: if isOwner(userId) && 
                      request.resource.size < 10 * 1024 * 1024 && // Max 10MB
                      request.resource.contentType.matches('application/pdf');
      
      // Users can update their own PDFs, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Users can delete their own PDFs, admins can delete any
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // ========================================
    // AUDIO FILES (Practice recordings)
    // ========================================
    match /audio/{userId}/{sessionId}/{fileName} {
      // Users can read their own audio, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can upload their own audio
      allow create: if isOwner(userId) && 
                      request.resource.size < 50 * 1024 * 1024 && // Max 50MB
                      request.resource.contentType.matches('audio/.*');
      
      // Users can update their own audio, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Users can delete their own audio, admins can delete any
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // ========================================
    // VIDEO FILES (Optional - for video practice)
    // ========================================
    match /videos/{userId}/{sessionId}/{fileName} {
      // Users can read their own videos, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can upload their own videos
      allow create: if isOwner(userId) && 
                      request.resource.size < 100 * 1024 * 1024 && // Max 100MB
                      request.resource.contentType.matches('video/.*');
      
      // Users can update their own videos, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      
      // Users can delete their own videos, admins can delete any
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // ========================================
    // USER AVATARS/PROFILE IMAGES
    // ========================================
    match /avatars/{userId}/{fileName} {
      // Anyone authenticated can read avatars
      allow read: if request.auth != null;
      
      // Users can upload their own avatar
      allow create: if isOwner(userId) && 
                      request.resource.size < 2 * 1024 * 1024 && // Max 2MB
                      request.resource.contentType.matches('image/.*');
      
      // Users can update their own avatar
      allow update: if isOwner(userId);
      
      // Users can delete their own avatar
      allow delete: if isOwner(userId);
    }
    
    // ========================================
    // ADMIN FILES (Admin-only resources)
    // ========================================
    match /admin/{allPaths=**} {
      // Only admins can access
      allow read, write: if isAdmin();
    }
    
    // ========================================
    // QUESTION ATTACHMENTS (Admin managed)
    // ========================================
    match /questions/{questionId}/{fileName} {
      // Anyone authenticated can read question attachments
      allow read: if request.auth != null;
      
      // Only admins can upload/modify question attachments
      allow create, update, delete: if isAdmin() && 
                                       request.resource.size < 5 * 1024 * 1024; // Max 5MB
    }
    
    // ========================================
    // TEMPORARY FILES (Auto-delete after 24h)
    // ========================================
    match /temp/{userId}/{fileName} {
      // Users can access their own temp files
      allow read, write: if isOwner(userId);
    }
    
    // ========================================
    // PUBLIC FILES (Accessible to all)
    // ========================================
    match /public/{allPaths=**} {
      // Anyone can read public files
      allow read: if true;
      
      // Only admins can write public files
      allow write: if isAdmin();
    }
    
    // ========================================
    // BACKUPS (Admin only)
    // ========================================
    match /backups/{allPaths=**} {
      // Only admins can access backups
      allow read, write: if isAdmin();
    }
  }
}
