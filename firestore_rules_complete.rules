rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================================================
    // USER DOCUMENTS
    // ==================================================
    match /users/{userId} {
      // Users can only read and write their own user document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow user creation during registration
      allow create: if request.auth != null && 
        request.auth.uid == userId &&
        validateUserData(request.resource.data);
    }
    
    // ==================================================
    // PRACTICE SESSIONS
    // ==================================================
    match /practice_sessions/{sessionId} {
      // Users can read and write their own practice sessions
      allow read, write: if request.auth != null && 
        request.auth.uid == resource.data.userId;
      
      // Allow creation of new practice sessions
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId &&
        validatePracticeSession(request.resource.data);
      
      // Allow updates only by session owner
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.userId &&
        request.auth.uid == request.resource.data.userId;
      
      // Allow deletion only by session owner
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // ==================================================
    // USER STATISTICS & ANALYTICS (Optional)
    // ==================================================
    match /user_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ==================================================
    // SYSTEM COLLECTIONS (Read-only for users)
    // ==================================================
    match /app_config/{document} {
      // Allow all authenticated users to read app configuration
      allow read: if request.auth != null;
      // Only admins can write (implement admin check if needed)
      allow write: if false; // Change to admin check in production
    }
    
    match /feedback/{feedbackId} {
      // Users can create feedback
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.userId;
      // Users can read their own feedback
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    
    // ==================================================
    // TEMPORARY: Allow all authenticated users (DEVELOPMENT ONLY)
    // REMOVE OR COMMENT OUT IN PRODUCTION
    // ==================================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // ==================================================
    // VALIDATION FUNCTIONS
    // ==================================================
    
    // Validate user data structure
    function validateUserData(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
        data.uid is string &&
        data.email is string &&
        data.displayName is string &&
        data.createdAt is timestamp;
    }
    
    // Validate practice session data structure
    function validatePracticeSession(data) {
      return data.keys().hasAll(['id', 'userId', 'mode', 'startTime']) &&
        data.id is string &&
        data.userId is string &&
        data.mode in ['interview', 'presentation'] &&
        data.startTime is timestamp;
    }
    
    // Check if user is admin (implement based on your admin system)
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.admin == true; // Custom claim
    }
    
    // Validate that user can only access their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Validate data size limits
    function isValidDataSize(data) {
      return request.resource.size < 1000000; // 1MB limit
    }
  }
}